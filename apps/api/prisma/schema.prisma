// Itsi Business — Prisma Schema
//
// RULE: Itsi Business owns the business customer.
//       Itsi Mobile owns the wholesale/provider fulfilment.
//
// This schema covers Itsi Business retail data only.
// Provider-side data lives in Itsi Mobile.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── RBAC ─────────────────────────────────────────────────────────────────────

model StaffUser {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  firstName    String
  lastName     String
  realm        String         @default("staff")
  roles        StaffRole[]
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("staff_users")
}

model StaffRole {
  id          String    @id @default(cuid())
  name        String    @unique
  permissions String[]
  staffUsers  StaffUser[]
  createdAt   DateTime  @default(now())

  @@map("staff_roles")
}

model PortalUser {
  id           String        @id @default(cuid())
  accountId    String
  email        String        @unique
  passwordHash String
  firstName    String
  lastName     String
  realm        String        @default("portal")
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  account      BusinessAccount @relation(fields: [accountId], references: [id])

  @@map("portal_users")
}

// ─── CRM ──────────────────────────────────────────────────────────────────────

model BusinessAccount {
  id            String                @id @default(cuid())
  accountNumber String                @unique
  companyName   String
  tradingName   String?
  companyNumber String?
  vatNumber     String?
  status        String                @default("PROSPECT")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  contacts       BusinessContact[]
  sites          BusinessSite[]
  contracts      BusinessContract[]
  invoices       BusinessInvoice[]
  payments       BusinessPayment[]
  tickets        BusinessTicket[]
  mobileServices BusinessMobileService[]
  broadbandServices BusinessBroadbandService[]
  energyServices BusinessEnergyService[]
  portalUsers    PortalUser[]
  timelineEvents TimelineEvent[]

  @@map("business_accounts")
}

model BusinessContact {
  id        String          @id @default(cuid())
  accountId String
  siteId    String?
  firstName String
  lastName  String
  email     String
  phone     String?
  role      String          @default("GENERAL")
  isPrimary Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  account   BusinessAccount @relation(fields: [accountId], references: [id])
  site      BusinessSite?   @relation(fields: [siteId], references: [id])

  @@map("business_contacts")
}

model BusinessSite {
  id           String          @id @default(cuid())
  accountId    String
  name         String
  addressLine1 String
  addressLine2 String?
  city         String
  county       String?
  postcode     String
  uprn         String?
  isPrimary    Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  account      BusinessAccount @relation(fields: [accountId], references: [id])
  contacts     BusinessContact[]
  broadbandServices BusinessBroadbandService[]
  energyServices    BusinessEnergyService[]
  tickets           BusinessTicket[]

  @@map("business_sites")
}

model BusinessContract {
  id            String          @id @default(cuid())
  accountId     String
  name          String
  startDate     DateTime?
  endDate       DateTime?
  status        String          @default("ACTIVE")
  terms         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  account       BusinessAccount @relation(fields: [accountId], references: [id])

  @@map("business_contracts")
}

// ─── BILLING ──────────────────────────────────────────────────────────────────

// Statuses: DRAFT → ISSUED → PART_PAID | PAID | OVERDUE | VOID
model BusinessInvoice {
  id              String          @id @default(cuid())
  invoiceNumber   String          @unique
  accountId       String
  status          String          @default("DRAFT")
  issueDate       DateTime?
  dueDate         DateTime?
  notes           String?
  // All monetary values stored in pence (integer)
  subtotalPence   Int             @default(0)
  taxTotalPence   Int             @default(0)
  discountTotalPence Int          @default(0)
  totalPence      Int             @default(0)
  amountPaidPence Int             @default(0)
  currency        String          @default("GBP")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  account         BusinessAccount @relation(fields: [accountId], references: [id])
  lines           BusinessInvoiceLine[]
  payments        BusinessPayment[]

  @@index([accountId, status])
  @@index([status, dueDate])
  @@map("business_invoices")
}

// Service types: MOBILE | BROADBAND | ENERGY | SOFTWARE | SUPPORT | OTHER
model BusinessInvoiceLine {
  id                       String          @id @default(cuid())
  invoiceId                String
  description              String
  serviceType              String?         // MOBILE | BROADBAND | ENERGY | SOFTWARE | SUPPORT | OTHER
  quantity                 Int             @default(1)
  unitPricePence           Int             @default(0)
  discountAmountPence      Int             @default(0)
  taxRate                  Float           @default(0)   // e.g. 20.0 for 20%
  netAmountPence           Int             @default(0)   // (quantity * unitPrice) - discount
  taxAmountPence           Int             @default(0)   // netAmount * taxRate / 100
  grossAmountPence         Int             @default(0)   // netAmount + taxAmount
  businessServiceReference String?
  wholesaleCostReference   String?         // placeholder only — never populated via provider API
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  invoice                  BusinessInvoice @relation(fields: [invoiceId], references: [id])

  @@map("business_invoice_lines")
}

// Manual/offline payment record — not connected to any payment provider
model BusinessPayment {
  id          String          @id @default(cuid())
  invoiceId   String
  accountId   String
  amountPence Int
  currency    String          @default("GBP")
  method      String          @default("MANUAL")
  reference   String?
  notes       String?
  paidAt      DateTime        @default(now())
  recordedByStaffUserId String?
  createdAt   DateTime        @default(now())
  invoice     BusinessInvoice @relation(fields: [invoiceId], references: [id])
  account     BusinessAccount @relation(fields: [accountId], references: [id])

  @@index([invoiceId])
  @@index([accountId])
  @@map("business_payments")
}

// ─── SUPPORT / DESK ───────────────────────────────────────────────────────────

model BusinessTicket {
  id                           String          @id @default(cuid())
  ticketNumber                 String          @unique
  accountId                    String
  contactId                    String?
  siteId                       String?
  subject                      String
  description                  String?
  category                     String          @default("GENERAL")
  status                       String          @default("OPEN")
  priority                     String          @default("NORMAL")
  assignedToStaffUserId        String?
  wholesaleEscalationId        String?
  wholesaleEscalationReference String?
  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime        @updatedAt
  account                      BusinessAccount @relation(fields: [accountId], references: [id])
  site                         BusinessSite?   @relation(fields: [siteId], references: [id])
  threads                      BusinessTicketThread[]

  @@index([accountId, status])
  @@index([status, priority])
  @@map("business_tickets")
}

model BusinessTicketThread {
  id              String         @id @default(cuid())
  ticketId        String
  body            String
  authorType      String
  authorId        String
  isInternal      Boolean        @default(false)
  customerVisible Boolean        @default(true)
  createdAt       DateTime       @default(now())
  ticket          BusinessTicket @relation(fields: [ticketId], references: [id])

  @@map("business_ticket_threads")
}

// ─── SERVICE CATALOGUE ────────────────────────────────────────────────────────
// Itsi Business-owned retail product catalogue.
// Service types: MOBILE | BROADBAND | ENERGY | SOFTWARE | SUPPORT | OTHER
// Statuses: ACTIVE | INACTIVE | ARCHIVED

model BusinessServiceCatalogueItem {
  id                         String   @id @default(cuid())
  sku                        String   @unique
  name                       String
  description                String?
  serviceType                String   // MOBILE | BROADBAND | ENERGY | SOFTWARE | SUPPORT | OTHER
  status                     String   @default("ACTIVE") // ACTIVE | INACTIVE | ARCHIVED
  retailPricePence           Int      @default(0)
  wholesaleCostEstimatePence Int?
  setupFeePence              Int?
  contractTermMonths         Int?
  taxRate                    Float    @default(20.0)
  marginPolicy               String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  mobileServices    BusinessMobileService[]
  broadbandServices BusinessBroadbandService[]
  energyServices    BusinessEnergyService[]

  @@index([serviceType, status])
  @@map("business_service_catalogue_items")
}

// ─── SERVICES ─────────────────────────────────────────────────────────────────
// Itsi Business-owned retail service records.
// Statuses: DRAFT | REQUESTED | ACTIVE | SUSPENDED | CEASED | CANCELLED

model BusinessMobileService {
  id                     String                        @id @default(cuid())
  accountId              String
  contactId              String?
  siteId                 String?
  catalogueItemId        String?
  serviceReference       String                        @unique
  displayName            String
  status                 String                        @default("DRAFT")
  retailPricePence       Int                           @default(0)
  contractStartDate      DateTime?
  contractEndDate        DateTime?
  mobileNumber           String?
  simLabel               String?
  costCentre             String?
  wholesaleServiceLinkId String?
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  account                BusinessAccount               @relation(fields: [accountId], references: [id])
  catalogueItem          BusinessServiceCatalogueItem? @relation(fields: [catalogueItemId], references: [id])
  wholesaleLink          ItsiMobileWholesaleServiceLink? @relation(fields: [wholesaleServiceLinkId], references: [id])

  @@index([accountId, status])
  @@map("business_mobile_services")
}

model BusinessBroadbandService {
  id                     String                        @id @default(cuid())
  accountId              String
  siteId                 String
  catalogueItemId        String?
  serviceReference       String                        @unique
  displayName            String
  status                 String                        @default("DRAFT")
  retailPricePence       Int                           @default(0)
  contractStartDate      DateTime?
  contractEndDate        DateTime?
  accessTechnology       String?
  postcode               String
  uprn                   String?
  circuitLabel           String?
  wholesaleServiceLinkId String?
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  account                BusinessAccount               @relation(fields: [accountId], references: [id])
  site                   BusinessSite                  @relation(fields: [siteId], references: [id])
  catalogueItem          BusinessServiceCatalogueItem? @relation(fields: [catalogueItemId], references: [id])
  wholesaleLink          ItsiMobileWholesaleServiceLink? @relation(fields: [wholesaleServiceLinkId], references: [id])

  @@index([accountId, status])
  @@map("business_broadband_services")
}

// Statuses: DRAFT | ACTIVE | SUSPENDED | CEASED
// Fuel types: ELECTRICITY | GAS | DUAL_FUEL
model BusinessEnergyService {
  id                     String                        @id @default(cuid())
  accountId              String
  siteId                 String
  catalogueItemId        String?
  serviceReference       String                        @unique
  displayName            String
  status                 String                        @default("DRAFT")
  fuelType               String                        @default("ELECTRICITY")
  meterPointReference    String?
  retailPriceDescription String?
  contractStartDate      DateTime?
  contractEndDate        DateTime?
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  account                BusinessAccount               @relation(fields: [accountId], references: [id])
  site                   BusinessSite                  @relation(fields: [siteId], references: [id])
  catalogueItem          BusinessServiceCatalogueItem? @relation(fields: [catalogueItemId], references: [id])

  @@index([accountId, status])
  @@map("business_energy_services")
}

// ─── WHOLESALE LINK ───────────────────────────────────────────────────────────
// Itsi Business-owned link to an Itsi Mobile wholesale order/service.
// Itsi Mobile owns the provider-side fulfilment.
// RULE: Itsi Business may call Itsi Mobile wholesale APIs via the bridge client.
//       Itsi Business must NOT call Gamma, KCOM, MS3, OTS Hero, or provider APIs.

model ItsiMobileWholesaleServiceLink {
  id                          String   @id @default(cuid())
  businessAccountId           String
  businessServiceType         String   // MOBILE | BROADBAND
  businessServiceReference    String
  itsiMobileWholesaleOrderId  String?
  itsiMobileServiceOrderId    String?
  safeProviderReference       String?
  status                      String   @default("PLACEHOLDER") // PLACEHOLDER | PENDING | ACTIVE | CEASED
  lastSyncedAt                DateTime?
  lastStatusCheckedAt         DateTime?
  lastStatusResponse          Json?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  mobileServices    BusinessMobileService[]
  broadbandServices BusinessBroadbandService[]

  @@index([businessAccountId])
  @@index([businessServiceReference])
  @@map("itsi_mobile_wholesale_service_links")
}

// ─── AUDIT / TIMELINE ─────────────────────────────────────────────────────────

model TimelineEvent {
  id          String          @id @default(cuid())
  type        String
  accountId   String
  actorId     String?
  actorType   String          @default("SYSTEM")
  meta        Json            @default("{}")
  occurredAt  DateTime        @default(now())
  account     BusinessAccount @relation(fields: [accountId], references: [id])

  @@index([accountId, occurredAt])
  @@map("timeline_events")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  actorId    String?
  actorType  String   @default("SYSTEM")
  meta       Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@map("audit_logs")
}
