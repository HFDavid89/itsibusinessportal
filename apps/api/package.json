{
  "name": "@itsi-business/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:migrate:prod": "prisma migrate deploy --schema=prisma/schema.prisma",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "test:wholesale-contract": "tsx --test src/services/wholesale/wholesale-contract.test.ts",
    "test:wholesale-simulated": "tsx --test src/services/wholesale/wholesale-simulated.test.ts",
    "test:wholesale": "tsx --test src/services/wholesale/wholesale-contract.test.ts src/services/wholesale/wholesale-simulated.test.ts",
    "test:sla": "tsx --test src/services/work-items/sla-policy.test.ts",
    "test": "pnpm test:wholesale && pnpm test:sla"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.2.2",
    "@itsi-business/auth": "workspace:*",
    "@itsi-business/core": "workspace:*",
    "@itsi-business/database": "workspace:*",
    "@itsi-business/timeline": "workspace:*",
    "@itsi-business/types": "workspace:*",
    "@prisma/client": "~6.19.3",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.3.2",
    "tsx": "^4.19.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "prisma": "~6.19.3",
    "typescript": "^5.6.2"
  }
}
