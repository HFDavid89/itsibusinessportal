{
  "name": "itsi-business-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --names \"api,admin,crm,billing,desk,services,portal\" --prefix-colors \"cyan,magenta,green,blue,yellow,teal,gray\" \"pnpm --filter @itsi-business/api dev\" \"pnpm --filter @itsi-business/admin dev\" \"pnpm --filter @itsi-business/crm dev\" \"pnpm --filter @itsi-business/billing dev\" \"pnpm --filter @itsi-business/desk dev\" \"pnpm --filter @itsi-business/services dev\" \"pnpm --filter @itsi-business/portal dev\"",
    "dev:api": "pnpm --filter @itsi-business/api dev",
    "dev:admin": "pnpm --filter @itsi-business/admin dev",
    "dev:crm": "pnpm --filter @itsi-business/crm dev",
    "dev:billing": "pnpm --filter @itsi-business/billing dev",
    "dev:desk": "pnpm --filter @itsi-business/desk dev",
    "dev:services": "pnpm --filter @itsi-business/services dev",
    "dev:portal": "pnpm --filter @itsi-business/portal dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "db:migrate": "pnpm --filter @itsi-business/api db:migrate",
    "db:seed": "pnpm --filter @itsi-business/api db:seed",
    "db:studio": "pnpm --filter @itsi-business/api db:studio"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.6.2",
    "turbo": "^2.5.3",
    "typescript": "^5.6.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.5",
      "@types/react-dom": "^18.3.0"
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.6"
}
