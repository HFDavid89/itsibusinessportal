# Itsi Business Platform — Environment Variables
# Copy this file to .env and fill in the values.
# Do NOT commit .env to version control.

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/itsi_business"

# ─── API ───────────────────────────────────────────────────────────────────────
PORT=4001
HOST=0.0.0.0
NODE_ENV=development

# ─── JWT / Auth ────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="8h"
COOKIE_SECRET="change-me-in-production"

# ─── Seed Bootstrap ────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@itsi.business"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# ─── Itsi Mobile Wholesale API ─────────────────────────────────────────────────
# RULE: Itsi Business owns the business customer.
#       Itsi Mobile owns the wholesale/provider fulfilment.
#
# These variables connect to the Itsi Mobile wholesale API boundary.
# They do NOT expose Gamma, KCOM, MS3 or OTS Hero credentials directly.
#
ITSI_MOBILE_API_BASE_URL=""
ITSI_MOBILE_WHOLESALE_API_KEY=""
ITSI_MOBILE_WHOLESALE_ENABLED="false"
ITSI_MOBILE_WHOLESALE_TIMEOUT_MS="10000"

# ─── App URLs (staff workspaces) ───────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_URL="http://localhost:4005"
NEXT_PUBLIC_CRM_URL="http://localhost:4006"
NEXT_PUBLIC_BILLING_URL="http://localhost:4007"
NEXT_PUBLIC_DESK_URL="http://localhost:4008"
NEXT_PUBLIC_PORTAL_URL="http://localhost:4009"

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="info"
