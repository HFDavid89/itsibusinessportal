# Itsi Business Platform — Environment Variables
# Copy this file to .env and fill in the values.
# Do NOT commit .env to version control.

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/itsi_business"

# ─── API ───────────────────────────────────────────────────────────────────────
PORT=17001
HOST=0.0.0.0
NODE_ENV=development

# ─── JWT / Auth ────────────────────────────────────────────────────────────────
JWT_SECRET="CHANGE_ME_use_openssl_rand_base64_32"
JWT_EXPIRES_IN="8h"
COOKIE_SECRET="CHANGE_ME_use_openssl_rand_base64_32"

# ─── Seed Bootstrap ────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@itsibusiness.co.uk"
SEED_ADMIN_PASSWORD="CHANGE_ME_min_12_chars"

# ─── Itsi Mobile Wholesale API ─────────────────────────────────────────────────
# RULE: Itsi Business owns the business customer.
#       Itsi Mobile owns the wholesale/provider fulfilment.
#
# These variables connect to the Itsi Mobile wholesale API boundary.
# They do NOT expose Gamma, KCOM, MS3 or OTS Hero credentials directly.
#
ITSI_MOBILE_API_BASE_URL="https://wholesale.itsimobile.co.uk"
ITSI_MOBILE_WHOLESALE_API_KEY="CHANGE_ME"
ITSI_MOBILE_WHOLESALE_ENABLED="false"
ITSI_MOBILE_WHOLESALE_TIMEOUT_MS="10000"
ITSI_MOBILE_WHOLESALE_RETRY_ATTEMPTS="3"
ITSI_MOBILE_WHOLESALE_CIRCUIT_BREAKER_ENABLED="true"

# ─── API URL (used by frontend apps) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:17001"

# ─── App URLs (staff workspaces) ───────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_URL="http://localhost:17005"
NEXT_PUBLIC_CRM_URL="http://localhost:17006"
NEXT_PUBLIC_BILLING_URL="http://localhost:17007"
NEXT_PUBLIC_DESK_URL="http://localhost:17008"
NEXT_PUBLIC_PORTAL_URL="http://localhost:17009"
NEXT_PUBLIC_SERVICES_URL="http://localhost:17010"

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS="http://localhost:17005,http://localhost:17006,http://localhost:17007,http://localhost:17008,http://localhost:17009,http://localhost:17010"

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="info"
